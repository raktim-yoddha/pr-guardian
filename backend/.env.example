# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL async connection string for the main database
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prguardian

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================
# Secret key used to sign JWT tokens - use a long random string in production
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
# JWT access token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =============================================================================
# GITHUB APP CONFIGURATION
# =============================================================================
# GitHub App ID for production mode (used for GitHub App authentication)
GITHUB_APP_ID=your_github_app_id
# GitHub App slug (the /apps/<slug> URL part)
GITHUB_APP_SLUG=pr-guardian
# Path to the GitHub App private key file (.pem format)
GITHUB_APP_PRIVATE_KEY_PATH=./github-app.pem
# Secret for validating GitHub webhook signatures (HMAC-SHA256)
GITHUB_WEBHOOK_SECRET=change-me-webhook-secret
# Optional: Personal Access Token for development mode (fallback for GitHub API)
GITHUB_TOKEN=

# =============================================================================
# GITHUB OAUTH CONFIGURATION
# =============================================================================
# GitHub OAuth App Client ID from https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
# GitHub OAuth App Client Secret from https://github.com/settings/developers
GITHUB_CLIENT_SECRET=your_github_client_secret
# OAuth callback URL - must match what's configured in GitHub OAuth App settings
# For local dev: http://localhost:3000/oauth/callback?provider=github
# For production: https://your-domain.com/oauth/callback?provider=github
GITHUB_REDIRECT_URI=http://localhost:3000/oauth/callback?provider=github

# =============================================================================
# GOOGLE OAUTH CONFIGURATION
# =============================================================================
# Google OAuth Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id
# Google OAuth Client Secret from Google Cloud Console
GOOGLE_CLIENT_SECRET=your_google_client_secret
# OAuth callback URL - must match what's configured in Google OAuth settings
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback?provider=google

# =============================================================================
# LLM CONFIGURATION (CHAT)
# =============================================================================
# Default chat provider when a user hasn't set their own in Settings.
#   groq   = Groq API (free, fast) — default
#   gemini = Google Gemini
#   ollama = local Ollama server
LLM_PROVIDER=groq

# Groq — get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (optional) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama (optional local provider)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# =============================================================================
# EMBEDDINGS (LOCAL CPU — no external service, no key)
# =============================================================================
# fastembed downloads a small ONNX model once (~130MB) and runs on CPU.
# EMBEDDING_DIM must match the model: bge-small-en-v1.5 = 384.
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# =============================================================================
# RAG CONFIGURATION
# =============================================================================
# Maximum tokens per chunk when splitting documents for the knowledge base
RAG_CHUNK_TOKENS=512
# Token overlap between adjacent chunks for context preservation
RAG_CHUNK_OVERLAP=50
# Number of top chunks to retrieve during RAG queries
RAG_TOP_K=8

# =============================================================================
# INGESTION CONFIGURATION
# =============================================================================
# Maximum number of files to ingest per repository (prevents runaway ingestion)
INGESTION_MAX_FILES=5000
# Maximum file size in bytes to ingest (files larger than this are skipped)
INGESTION_MAX_FILE_BYTES=524288
# Comma-separated list of file extensions to include in ingestion
INGESTION_TEXT_EXTS=.py,.js,.ts,.tsx,.jsx,.go,.rs,.java,.kt,.rb,.php,.c,.cc,.cpp,.h,.hpp,.cs,.swift,.m,.mm,.scala,.clj,.ex,.exs,.erl,.hs,.ml,.lua,.pl,.r,.sh,.bash,.zsh,.fish,.ps1,.bat,.cmd,.yml,.yaml,.toml,.ini,.cfg,.conf,.json,.jsonc,.xml,.html,.css,.scss,.sass,.less,.vue,.svelte,.md,.rst,.txt,.sql,.graphql,.gql,.proto,.dockerfile,.env.example,.gitignore,.gitattributes

# =============================================================================
# PIPELINE CONFIGURATION
# =============================================================================
# Spam detection threshold (0.0-1.0) - PRs with score above this are declined
SPAM_THRESHOLD=0.75
# Number of flags required to auto-ban a GitHub account
FLAG_BAN_THRESHOLD=3
# Maximum webhook payload size in bytes (PRs larger than this are ignored)
MAX_PR_DIFF_BYTES=524288
